# GERE com: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=GERE_UMA_SECRET_KEY_AQUI

# Em producao: False
DEBUG=False

# Em producao: liste IPs/dominios separados por virgula (NUNCA use *)
ALLOWED_HOSTS=seu-ip-ou-dominio

# Em producao: liste URLs do frontend (com protocolo)
CORS_ALLOWED_ORIGINS=http://seu-ip-ou-dominio
CSRF_TRUSTED_ORIGINS=http://seu-ip-ou-dominio

DJANGO_ADMIN_USER=admin
DJANGO_ADMIN_EMAIL=seuemail@exemplo.com
# Em producao: use senha forte
DJANGO_ADMIN_PASSWORD=TROQUE_ESTA_SENHA

# Banco de dados (PostgreSQL)
DB_NAME=kanban_db
DB_USER=kanban_user
DB_PASSWORD=TROQUE_ESTA_SENHA_DO_BANCO
DB_HOST=db
DB_PORT=5432
